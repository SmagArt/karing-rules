{
  "rules": [
    {
      "outbound": "block",
      "name": "🛑 Adblock",
      "switch": true,
      "or": true,
      "rule_set_build_in": [
        "acl:BanAD",
        "geosite:category-ads"
      ]
    },
    {
      "outbound": "block",
      "name": "🍃 AdblockPlus",
      "switch": true,
      "or": true,
      "rule_set_build_in": [
        "acl:BanProgramAD",
        "acl:BanADCompany"
      ]
    },
    {
      "outbound": "block",
      "name": "🛑 malware",
      "switch": true,
      "or": true,
      "rule_set_build_in": [
        "geosite:malware",
        "geoip:malware",
        "geoip:phishing",
        "geosite:phishing",
        "geosite:cryptominers"
      ]
    },
    {
      "outbound": "direct",
      "name": "🍎 Apple",
      "switch": true,
      "or": true,
      "rule_set_build_in": [
        "geosite:apple",
        "geosite:apple-ads",
        "geosite:apple-dev",
        "geosite:apple-pki",
        "geosite:apple-update"
      ]
    },
    {
